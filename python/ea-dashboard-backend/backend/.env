# Backend Settings
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
DEBUG=True

# Database
#DATABASE_URL=sqlite:///:memory:
DATABASE_URL=sqlite:///./data.db
DATABASE_ECHO=False

# Frontend CORS
FRONTEND_URL=http://localhost:3000

# WebSocket
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/backend.log